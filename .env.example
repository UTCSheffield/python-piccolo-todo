# Optional environment settings.
# Piccolo uses SQLite at ./todo.sqlite by default via piccolo_conf.py.
#
# WARNING: Do not add real secrets to this file — it is committed to git.
# Copy to .env and fill in values there: cp .env.example .env

APP_NAME=piccolo-todo-api

# Optional: bootstrap first admin user at startup.
# Only used when no superuser exists in the database.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
